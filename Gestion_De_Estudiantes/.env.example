# JWT (producción)
JWT_SECRET=change-me-use-openssl-rand-base64-32

# WhatsApp bridge
WHATSAPP_BRIDGE_API_KEY=
WHATSAPP_BRIDGE_URL=http://localhost:3001

# Perfil Spring: default (SQLite) | prod (PostgreSQL)
SPRING_PROFILES_ACTIVE=default

# PostgreSQL (solo perfil prod)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=colegio_acceso
DB_USER=colegio
DB_PASSWORD=colegio123

# WhatsApp Business API (opcional, whatsapp.provider=business-api)
WHATSAPP_PROVIDER=bridge
WHATSAPP_BUSINESS_API_URL=
WHATSAPP_BUSINESS_API_TOKEN=
